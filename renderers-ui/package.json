{
  "name": "@the-syllabus/analysis-renderers",
  "version": "0.6.3",
  "description": "Shared renderer components for analyzer-v2 view definitions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node scripts/generate-version-module.mjs && tsc && cp -r src/styles dist/",
    "watch": "node scripts/generate-version-module.mjs && tsc --watch",
    "release:pack": "node scripts/release-pack.mjs",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/styles/index.css"
  },
  "license": "MIT"
}
