{
  "view_key": "genealogy_relationship_landscape",
  "view_name": "Relationship Landscape",
  "description": "Shows which prior works are direct precursors vs. indirect contextualizers vs. counter-positions. Surfaces the Pass 1.5 relationship classification data that exists per-work but isn't currently visible in the UI.",
  "version": 1,
  "target_app": "the-critic",
  "target_page": "genealogy",
  "target_section": "results",
  "renderer_type": "card_grid",
  "renderer_config": {
    "cell_renderer": "template_card",
    "group_by": "relationship_type",
    "group_style_map": "relationship",
    "columns": 1,
    "expandable": false,
    "card_template": {
      "slots": [
        { "type": "badge_row", "badges": [
          { "field": "relationship_type", "color_mode": "category", "color_category": "relationship" },
          { "field": "relationship_strength", "color_mode": "category", "color_category": "strength" }
        ]},
        { "type": "heading", "field": "work_title" },
        { "type": "prose", "field": "summary" },
        { "type": "chip_list", "field": "influence_channels", "label": "Influence Channels",
          "item_label_field": "channel", "item_tooltip_field": "description" },
        { "type": "chip_list", "field": "vocabulary_contributed", "label": "Vocabulary Contributed" },
        { "type": "evidence_trail", "label": "Key Evidence", "collapsed_by_default": true, "steps": [
          { "label": "Evidence", "field": "key_evidence", "variant": "current",
            "item_title_field": "evidence_type", "item_quote_field": "quote", "item_body_field": "description" }
        ]},
        { "type": "prose", "field": "centrality_assessment", "label": "Centrality" },
        { "type": "prose", "field": "what_would_be_lost", "label": "Without This Work", "subdued_when": "always" }
      ]
    }
  },
  "data_source": {
    "workflow_key": "intellectual_genealogy",
    "phase_number": 1.5,
    "engine_key": "genealogy_relationship_classification",
    "result_path": "",
    "scope": "per_item"
  },
  "secondary_sources": [],
  "transformation": {
    "type": "none"
  },
  "presentation_stance": "diagnostic",
  "position": 1.0,
  "parent_view_key": null,
  "tab_count_field": null,
  "visibility": "if_data_exists",
  "audience_overrides": {},
  "planner_hint": "Primary when 3+ prior works are being analyzed. Shows relationship types and strength for each prior work.",
  "planner_eligible": true,
  "status": "active",
  "tags": ["genealogy", "relationships", "classification"],
  "source_project": "critic"
}
